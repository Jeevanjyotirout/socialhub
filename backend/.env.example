# ── Required ──────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./socialhub.db

# ── CORS ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Limits ─────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=500
MAX_DOWNLOADS_PER_HOUR=20
